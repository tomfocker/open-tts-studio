{
  "name": "open-tts-desktop",
  "version": "0.1.0",
  "description": "A local desktop workstation for managing open-source TTS models.",
  "author": "tomfocker",
  "homepage": "https://github.com/tomfocker/open-tts-studio",
  "repository": {
    "type": "git",
    "url": "https://github.com/tomfocker/open-tts-studio.git"
  },
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "desktop": "npm run build && set OPEN_TTS_DESKTOP_FORCE_DIST=1&& electron electron/main.cjs",
    "electron": "electron electron/main.cjs",
    "test:electron": "node --test electron/*.test.cjs",
    "prepare:runtime": "node electron/prepare-python-runtime.cjs",
    "package:dir": "npm run prepare:runtime && npm run build && electron-builder --win dir --x64",
    "package:portable": "npm run prepare:runtime && npm run build && electron-builder --win portable --x64",
    "package:win": "npm run prepare:runtime && npm run build && electron-builder --win nsis portable --x64"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.468.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^31.0.0",
    "electron-builder": "^26.15.3",
    "playwright-core": "^1.60.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.tomfocker.openttsstudio",
    "productName": "OpenTTS Studio",
    "artifactName": "OpenTTS-Studio-${version}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../api",
        "to": "workspace/apps/api",
        "filter": [
          "**/*",
          "!tests{,/**/*}",
          "!tools{,/**/*}",
          "!.venv{,/**/*}",
          "!.pytest_cache{,/**/*}",
          "!**/__pycache__{,/**/*}"
        ]
      },
      {
        "from": ".runtime/python",
        "to": "workspace/runtime/python"
      },
      {
        "from": "../../model-registry",
        "to": "workspace/model-registry"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "artifactName": "OpenTTS-Studio-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "OpenTTS-Studio-Portable-${version}-${arch}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "tomfocker",
        "repo": "open-tts-studio"
      }
    ]
  }
}
